---
import PsicMerrleLogo from './icons/logo.svg';
---

<section class="w-dvw h-dvh bg-accent-dark flex flex-col-reverse xl:flex-row justify-center items-center">
  
    <div class="flex flex-col items-center xl:items-start">
      <h1 class="font-serif-accent text-accent text-4xl xl:text-6xl leading-20">Tu espacio seguro</h1>
      <span class="text-accent text-md xl:text-2xl text-center lg:text-start">Siempre hay un lugar para ti.</span>
      <span class="text-accent text-md xl:text-2xl text-center lg:text-start">Tu presencia importa más de lo que piensas.</span>
      <a
        href="https://wa.me/526861878075?text=Hola!%20Vi%20tu%20página%20y%20me%20gustaría%20agendar%20una%20cita"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-button block xl:hidden px-8 py-4 mt-4 text-lg font-semibold text-dark bg-accent rounded-full transition-all duration-300 hover:scale-105 hover:shadow-2xl"
      >
        Agendar consulta
      </a>
    </div>
    <div class="flex flex-col items-center justify-center xl:justify-start basis-1/2 relative z-10">
      <div class="flex leading-0 flex-wrap lg:text-7xl justify-center items-end font-bold">
        <div class="w-full flex justify-end">
          <PsicMerrleLogo name="logo" class="self-end w-20 h-20 lg:w-50 lg:h-50"/>
          <p class="flex flex-col">
            <span class="text-7xl leading-12 sm:text-8xl lg:text-9xl lg:leading-20 text-center xl:text-end font-serif font-bold text-accent">merrle</span>
            <span class="text-7xl leading-12 sm:text-8xl lg:text-9xl lg:leading-20 text-center xl:text-end font-serif font-bold text-accent">gomez</span>
          </p>
        </div>
        <div class="hidden w-full xl:flex justify-end">
          <a
            href="https://wa.me/526861878075?text=Hola!%20Vi%20tu%20página%20y%20me%20gustaría%20agendar%20una%20cita"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-button px-8 py-4 text-lg font-semibold text-dark bg-accent rounded-full transition-all duration-300 hover:scale-105 hover:shadow-2xl"
          >
            Agendar consulta
          </a>
        </div>
      </div>
    </div>
</section>
